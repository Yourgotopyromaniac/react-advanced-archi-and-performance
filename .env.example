# Copy this file to `.env` (or `.env.local`) and fill in the value.
# Get a free TMDB v4 "API Read Access Token" from:
#   https://www.themoviedb.org/settings/api
# (Create an account → Settings → API → request a developer key → copy
# the long "API Read Access Token", NOT the short v3 "API Key".)

VITE_TMDB_TOKEN=

# Optional overrides — defaults are sensible.
# VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
# VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
